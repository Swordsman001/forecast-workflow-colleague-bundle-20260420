{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nonstandard-forecast-rollforward/workbook_map.schema.json",
  "title": "Workbook Map",
  "type": "object",
  "required": [
    "workbook",
    "main_modeling_sheet",
    "main_modeling_sheet_index",
    "header_row",
    "label_column",
    "historical_columns",
    "forecast_columns",
    "rollforward_pattern",
    "current_headers",
    "current_forecast_window",
    "summary_extension_status",
    "row_registry",
    "writable_driver_targets",
    "formula_rows",
    "display_rows",
    "map_validation_hints"
  ],
  "properties": {
    "workbook": {
      "type": "string",
      "minLength": 1
    },
    "main_modeling_sheet": {
      "type": "string",
      "minLength": 1
    },
    "main_modeling_sheet_index": {
      "type": "integer",
      "minimum": 0
    },
    "header_row": {
      "type": "integer",
      "minimum": 1
    },
    "label_column": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ]
    },
    "historical_columns": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "forecast_columns": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rollforward_pattern": {
      "type": "object",
      "required": [
        "reported_col",
        "forecast_start_col",
        "new_far_year_col"
      ],
      "properties": {
        "reported_col": {
          "type": "string"
        },
        "forecast_start_col": {
          "type": "string"
        },
        "new_far_year_col": {
          "type": "string"
        }
      }
    },
    "current_headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "current_forecast_window": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary_extension_status": {
      "type": "object"
    },
    "row_registry": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rowRegistryItem"
      }
    },
    "writable_driver_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formula_rows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "display_rows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "map_validation_hints": {
      "type": "object"
    }
  },
  "$defs": {
    "rowRegistryItem": {
      "type": "object",
      "required": [
        "row_id",
        "sheet",
        "row",
        "label",
        "role",
        "writable",
        "required_years",
        "must_extend_to_far_year"
      ],
      "properties": {
        "row_id": {
          "type": "string",
          "minLength": 1
        },
        "sheet": {
          "type": "string",
          "minLength": 1
        },
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "driver_input",
            "formula_derived",
            "display_formula",
            "summary_display",
            "tie_out_check"
          ]
        },
        "writable": {
          "type": "boolean"
        },
        "required_years": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "must_extend_to_far_year": {
          "type": "boolean"
        },
        "year_cells": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "basis_paths": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "formula_template": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_row_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "style_source_col": {
          "type": [
            "string",
            "null"
          ]
        },
        "display_write_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "verify",
            "rewrite",
            null
          ]
        },
        "validation": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "writable": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "year_cells",
              "basis_paths"
            ]
          }
        }
      ]
    }
  }
}
