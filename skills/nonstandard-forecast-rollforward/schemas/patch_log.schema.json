{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude.local/nonstandard-forecast-rollforward/patch_log.schema.json",
  "title": "Patch Log",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "sheet",
      "cell",
      "row_id",
      "year",
      "before",
      "after",
      "write_type",
      "instruction_id",
      "basis_ref",
      "review_flag",
      "formula_preserved",
      "parity_audit_status",
      "instruction_hash",
      "basis_hash",
      "map_hash",
      "evidence_hash",
      "output_hash"
    ],
    "properties": {
      "sheet": {
        "type": "string",
        "minLength": 1
      },
      "cell": {
        "type": "string",
        "pattern": "^[A-Z]+[0-9]+$"
      },
      "row_id": {
        "type": "string",
        "minLength": 1
      },
      "year": {
        "type": "string",
        "minLength": 1
      },
      "before": {},
      "after": {},
      "write_type": {
        "type": "string",
        "enum": [
          "value",
          "formula",
          "verification_target"
        ]
      },
      "instruction_id": {
        "type": "string",
        "minLength": 1
      },
      "basis_ref": {
        "type": [
          "string",
          "null"
        ]
      },
      "review_flag": {
        "type": [
          "string",
          "null"
        ]
      },
      "formula_preserved": {
        "type": [
          "boolean",
          "null"
        ]
      },
      "parity_audit_status": {
        "type": "string",
        "enum": [
          "pending",
          "passed",
          "failed"
        ]
      },
      "instruction_hash": {
        "type": [
          "string",
          "null"
        ]
      },
      "basis_hash": {
        "type": [
          "string",
          "null"
        ]
      },
      "map_hash": {
        "type": [
          "string",
          "null"
        ]
      },
      "evidence_hash": {
        "type": [
          "string",
          "null"
        ]
      },
      "output_hash": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
